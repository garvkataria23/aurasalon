# ─── Server ──────────────────────────────────────────────────────────────────
NODE_ENV=production
HOST=0.0.0.0
PORT=4000
# Comma-separated origins. Include your production domain.
CORS_ORIGINS=http://localhost:4000,https://your-salon-domain.example
REQUEST_BODY_LIMIT=1mb
LOG_LEVEL=info

# ─── Public URL ───────────────────────────────────────────────────────────────
# Full public-facing URL (used for booking links, receipt URLs, webhooks).
APP_PUBLIC_URL=https://your-salon-domain.example
PUBLIC_APP_URL=https://your-salon-domain.example
CLIENT_URL=https://your-salon-domain.example

# ─── Auth / Secrets ───────────────────────────────────────────────────────────
# IMPORTANT: Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
# Each of the three secrets MUST be a different random string. Never reuse them.
JWT_SECRET=REPLACE_WITH_64_CHAR_RANDOM_HEX
ENCRYPTION_SECRET=REPLACE_WITH_DIFFERENT_64_CHAR_RANDOM_HEX
JWT_ACCESS_TTL_SECONDS=900
JWT_REFRESH_TTL_DAYS=30

# ─── Demo / First Run ─────────────────────────────────────────────────────────
REQUIRE_PASSWORD_AUTH=true
# Change BEFORE first login. Minimum 12 characters.
DEMO_ADMIN_PASSWORD=REPLACE_BEFORE_FIRST_PRODUCTION_RUN

# ─── Database ─────────────────────────────────────────────────────────────────
# Directory where SQLite data files are stored (must be writable).
# Defaults to ./data if unset.
AURA_DATA_DIR=./data
AURA_DB_FILE=aura.db
# Optional encryption key for SQLite (SQLCipher). Generate same way as JWT_SECRET.
# Leave blank to use unencrypted SQLite.
AURA_DB_ENCRYPTION_KEY=
SQLITE_ENCRYPTION_KEY=
DB_ENCRYPTION_KEY=

# ─── Security ─────────────────────────────────────────────────────────────────
# 4-6 digit PIN required for privileged owner actions.
SECURITY_OWNER_PIN=
# PIN required to re-authenticate after session timeout.
SECURITY_REAUTH_PIN=
# Set to true in production to block localhost-origin API requests.
SECURITY_BLOCK_LOCALHOST=false
# Set to true to disable hCaptcha during local dev.
CAPTCHA_DISABLED=false

# ─── AI Provider ──────────────────────────────────────────────────────────────
# Options: local | openai | anthropic
AI_PROVIDER=local

# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini

# Anthropic Claude
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# AI rate-limiting / cost controls (all optional — sane defaults apply)
AI_DAILY_CALL_LIMIT=200
AI_DAILY_COST_LIMIT_USD=2.00
AI_COST_BUDGET_USD_PER_TENANT_PER_DAY=0.50
AI_MAX_PROMPT_CHARS=8000
AI_MAX_RETRIES=2
AI_REQUEST_TIMEOUT_MS=30000

# ─── Payment Providers ────────────────────────────────────────────────────────
# Razorpay (optional – leave blank to use local/cash-only mode)
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
RAZORPAY_PAYMENT_LINK_BASE=https://rzp.io/l/
# Set to true to override live settlement account routing for testing.
RAZORPAY_SETTLEMENT_OVERRIDE=false

# Cashfree (optional)
CASHFREE_CLIENT_ID=
CASHFREE_CLIENT_SECRET=
CASHFREE_WEBHOOK_SECRET=

# PhonePe (optional)
PHONEPE_MERCHANT_ID=
PHONEPE_SALT_KEY=
PHONEPE_SALT_INDEX=1

# ─── Meta / WhatsApp ──────────────────────────────────────────────────────────
# Meta Graph API version used for WhatsApp Business and review integrations.
META_GRAPH_VERSION=v20.0
