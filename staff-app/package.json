{
  "name": "aura-staff-app",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "staff": "npm start",
    "start": "ng serve --host 127.0.0.1 --port 4320 --proxy-config proxy.conf.json --prebundle=false",
    "start:lan": "ng serve --host 0.0.0.0 --port 4320 --proxy-config proxy.conf.json --prebundle=false",
    "build": "ng build",
    "cap:add:android": "npx cap add android",
    "cap:sync": "npx cap sync android",
    "cap:open:android": "npx cap open android",
    "apk:debug": "npm run build && npx cap sync android && android\\gradlew.bat -p android assembleDebug",
    "test": "vitest run",
    "test:e2e": "npx playwright test --config=playwright.config.ts",
    "test:e2e:mobile": "npx playwright test --config=playwright.config.ts --project=pixel-4 --project=iphone-se --project=pixel-7 --project=iphone-14 --project=pixel-8-pro --project=iphone-15-pro-max",
    "test:e2e:tablet": "npx playwright test --config=playwright.config.ts --project=ipad --project=ipad-pro",
    "test:e2e:desktop": "npx playwright test --config=playwright.config.ts --project=desktop-1280 --project=desktop-1920",
    "test:e2e:update-snapshots": "npx playwright test --config=playwright.config.ts --update-snapshots",
    "test:e2e:report": "npx playwright show-report playwright-report"
  },
  "dependencies": {
    "@angular/animations": "20.3.25",
    "@angular/common": "20.3.25",
    "@angular/compiler": "20.3.25",
    "@angular/core": "20.3.25",
    "@angular/forms": "20.3.25",
    "@angular/platform-browser": "20.3.25",
    "@angular/router": "20.3.25",
    "@capacitor/android": "^7.0.0",
    "@capacitor/app": "^7.0.0",
    "@capacitor/core": "^7.0.0",
    "@capacitor/push-notifications": "^7.0.0",
    "@ionic/angular": "^8.0.0",
    "rxjs": "~7.8.0",
    "tslib": "^2.8.0",
    "zone.js": "~0.15.0"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "20.3.32",
    "@angular/cli": "20.3.30",
    "@angular/compiler-cli": "20.3.25",
    "@capacitor/cli": "^7.6.8",
    "@playwright/test": "^1.61.1",
    "typescript": "~5.8.0",
    "vitest": "^3.2.6"
  }
}
